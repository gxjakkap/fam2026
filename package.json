{
  "name": "fam2026",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome check",
    "format": "biome format --write",
    "db:check": "bun run --filter @repo/db db:check",
    "db:generate": "bun run --filter @repo/db db:generate",
    "db:migrate": "bun run --filter @repo/db db:migrate",
    "db:gen-schema": "bun run --filter @repo/db db:gen-schema"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "turbo": "latest"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}