{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "allowImportingTsExtensions": true,
    "noEmit": true,
  },
  "include": ["src/**/*", "scripts/**/*", "../auth/scripts/create-admin.ts"],
  "exclude": ["dist", "node_modules"],
}
